# Spotify API credentials — required for the Music section to load live releases
#
# How to get these:
#   1. Go to https://developer.spotify.com/dashboard
#   2. Log in and click "Create app"
#   3. Name: "Men Aloho Website" | Redirect URI: http://localhost:3000
#   4. Copy the Client ID and Client Secret below
#
# Then rename this file to .env.local (git-ignored) and restart the dev server.

REACT_APP_SPOTIFY_CLIENT_ID=your_client_id_here
REACT_APP_SPOTIFY_CLIENT_SECRET=your_client_secret_here
